# ============================================================
# CONFIGURAÇÕES DO SERVIDOR
# ============================================================
PORT=3000
SESSION_SECRET=troque_por_uma_string_longa_e_aleatoria

# ============================================================
# AUTENTICAÇÃO GOOGLE OAUTH 2.0
# Crie em: https://console.cloud.google.com/ > APIs & Services > Credentials
# ============================================================
GOOGLE_CLIENT_ID=seu_client_id_aqui.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=seu_client_secret_aqui
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback

# URL do frontend (usado no redirect após login)
FRONTEND_URL=http://localhost:3000

# ============================================================
# GOOGLE SHEETS — IDs das planilhas
# ============================================================
SPREADSHEET_ID=1GH-NsJ4EkqD91p7SLUlDYLzJDs0M_ufameiq_VcNKpo
EXTERNAL_PROSPECCAO_SHEET_ID=1C_xlfj7_2p62eRnEDoMvwg9R4hIikFbxbmNE7Yl4LZg
EXTERNAL_PROSPECCAO_SHEET_NAME=Prospecção de Coordenadas

# ============================================================
# GOOGLE MAPS API KEY
# ============================================================
GOOGLE_MAPS_API_KEY=sua_api_key_aqui

# ============================================================
# GOOGLE SERVICE ACCOUNT (para BigQuery e Sheets sem OAuth do usuário)
# Baixe o JSON da service account e coloque o caminho aqui
# ============================================================
GOOGLE_APPLICATION_CREDENTIALS=./service-account.json

# ============================================================
# BIGQUERY
# ============================================================
BIGQUERY_PROJECT_ID=seu_project_id
BIGQUERY_DATASET=seu_dataset
BIGQUERY_TABLE_LEADS=sua_tabela_leads
BIGQUERY_TABLE_TREINAMENTO=sua_tabela_treinamento

# ============================================================
# DOMÍNIO PERMITIDO (apenas e-mails deste domínio podem acessar)
# Deixe vazio para permitir qualquer e-mail Google
# ============================================================
ALLOWED_DOMAIN=mercadolivre.com
